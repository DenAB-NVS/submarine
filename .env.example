# submarine environment variables
# Copy this file to .env only if you want to customize the defaults.
# Leaving .env absent (or leaving keys commented) is fully supported.

# API key for authenticating requests.
# LEAVE COMMENTED to run with authentication DISABLED (default, recommended for local use).
# UNCOMMENT and set a strong value to require the X-API-Key header on every request.
# SUBMARINE_API_KEY=change-me-to-a-strong-secret

# Server port (optional, default: 3100)
# SUBMARINE_PORT=3100

# Reserved for future use
# SUBMARINE_LOG_LEVEL=info
# SUBMARINE_DB_PATH=./data/lancedb
